# Media storage path — set to NAS mount point for production
# e.g., MEDIA_PATH=/mnt/nas/capture-media
MEDIA_PATH=./media

# Xiaohongshu video download cookies (optional).
# Only needed for capturing XHS *video* posts; XHS image posts and all X posts
# work without it. Point at a Netscape-format cookies.txt file exported from
# your browser. Leave commented out to skip.
# XHS_COOKIE_FILE=/path/to/xhs_cookies.txt

# HTTP proxy for X/Twitter capture (optional).
# Only needed if your network can't reach x.com directly. Leave empty otherwise.
# HTTPS_PROXY=http://127.0.0.1:7890

# Override if needed:
# DATABASE_URL=postgres://capture:capture@localhost:5432/capture?sslmode=disable
# NEXT_PUBLIC_BACKEND_URL=http://your-host:8080
